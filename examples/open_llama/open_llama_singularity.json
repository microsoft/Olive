{
    "azureml_client": {
        "subscription_id": "subscription_id",
        "resource_group": "resource_group",
        "workspace_name": "workspace_name",
        "default_auth_params": { "exclude_managed_identity_credential": true }
    },
    "input_model": {
        "type": "PyTorchModel",
        "config": { "hf_config": { "model_name": "openlm-research/open_llama_7b_v2", "task": "text-generation" } }
    },
    "systems": {
        "aml_system": {
            "type": "AzureML",
            "config": {
                "aml_compute": "/subscriptions/06237282-1ddd-4677-9878-5bc19cc0001a/resourceGroups/aip-framework-singularity-rg-01/providers/Microsoft.MachineLearningServices/virtualclusters/aip-framework",
                "aml_docker_config": {
                    "base_image": "ptebic.azurecr.io/public/aifx/acpt/stable-ubuntu2004-cu121-py38-torch210",
                    "conda_file_path": "conda.yaml"
                },
                "resources": {
                    "instance_type": "Singularity.ND5_v2",
                    "properties": { "AISuperComputer": { "interactive": true, "slaTier": "Premium" } }
                },
                "instance_count": 1
            }
        },
        "singularity": {
            "type": "AzureML",
            "config": {
                "aml_compute": "/subscriptions/81350224-85c9-4555-8948-ee131fb519a0/resourceGroups/amdmi100vc_rg/providers/Microsoft.MachineLearningServices/virtualClusters/amdmi100vc",
                "aml_docker_config": {
                    "base_image": "ptebic.azurecr.io/public/aifx/acpt/stable-ubuntu2004-rocm561-py38-torch201",
                    "conda_file_path": "conda.yaml"
                },
                "resources": {
                    "instance_type": "Singularity.MI100_1",
                    "properties": { "AISuperComputer": { "interactive": false, "slaTier": "Premium" } }
                },
                "instance_count": 1,
                "is_dev": true
            }
        }
    },
    "data_configs": {
        "tiny-codes-train": {
            "name": "tiny-codes-train",
            "type": "HuggingfaceContainer",
            "user_script": "lora_user_script.py",
            "components": { "load_dataset": { "type": "load_tiny_code_dataset" } },
            "params_config": {
                "data_name": "nampdn-ai/tiny-codes",
                "split": "train",
                "component_kwargs": {
                    "load_dataset": { "language": "Python", "token": true },
                    "pre_process_data": {
                        "dataset_type": "corpus",
                        "corpus_strategy": "join",
                        "text_template": "### Question: {prompt} \n### Answer: {response}",
                        "source_max_len": 1024
                    }
                }
            }
        }
    },
    "passes": {
        "lora": {
            "type": "LoRA",
            "config": {
                "lora_dropout": 0.1,
                "train_data_config": "tiny-codes-train",
                "eval_dataset_size": 1024,
                "training_args": {
                    "per_device_train_batch_size": 8,
                    "per_device_eval_batch_size": 8,
                    "gradient_accumulation_steps": 1,
                    "max_steps": 500,
                    "logging_steps": 100,
                    "evaluation_strategy": "steps",
                    "adam_beta2": 0.999,
                    "max_grad_norm": 0.3,
                    "load_best_model_at_end": true
                }
            }
        },
        "conversion": {
            "type": "OnnxConversion",
            "config": {
                "target_opset": 17,
                "save_as_external_data": true,
                "all_tensors_to_one_file": true,
                "torch_dtype": "float32"
            }
        },
        "transformers_optimization": {
            "type": "OrtTransformersOptimization",
            "disable_search": true,
            "config": {
                "save_as_external_data": true,
                "all_tensors_to_one_file": true,
                "model_type": "gpt2",
                "opt_level": 0,
                "only_onnxruntime": false,
                "keep_io_types": false,
                "float16": true,
                "optimization_options": { "enable_rotary_embeddings": false }
            }
        }
    },
    "engine": {
        "log_severity_level": 0,
        "search_strategy": false,
        "evaluate_input_model": false,
        "host": "aml_system",
        "target": "aml_system",
        "execution_providers": [ "CUDAExecutionProvider" ],
        "cache_dir": "cache",
        "output_dir": "models/open_llama_singularity"
    }
}
