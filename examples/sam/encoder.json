{
    "input_model": {
        "type": "PyTorchModel",
        "model_path": "facebook/sam-vit-base",
        "model_script": "user_script.py",
        "model_loader": "encoder_loader",
        "io_config": {
            "input_names": ["pixel_values"],
            "input_shapes": [[1, 3, 1024, 1024]],
            "input_types": ["float32"],
            "output_names": ["image_embeddings", "image_positional_embeddings"],
            "dynamic_axes": {
                "pixel_values": {
                  "0": "batch_size"
                },
                "image_embeddings": {
                  "0": "batch_size"
                },
                "image_positional_embeddings": {
                  "0": "batch_size"
                }
              }
        }
    },
    "passes": {
        "conversion": {
            "type": "OnnxConversion",
            "target_opset": 17
        }
    },
    "output_dir": "models"
}
