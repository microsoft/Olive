{
  "input_model": {
    "type": "CompositeModel",
    "config": {
      "model_path": "exported_pkg"
    }
  },
  "systems": {
    "local_gpu": {
      "type": "LocalSystem",
      "accelerators": [
        { "device": "gpu", "execution_providers": ["CUDAExecutionProvider"] }
      ]
    }
  },
  "data_configs": [
    {
      "name": "calib",
      "user_script": "user_script.py",
      "load_dataset_config": { "type": "local_dataset" }
    }
  ],
  "passes": {
    "transformer_opt": { "type": "OrtTransformersOptimization", "float16": true },
    "quantization": { "type": "OnnxStaticQuantization", "data_config": "calib" }
  },
  "engine": {
    "host": "local_gpu",
    "target": "local_gpu",
    "evaluate_input_model": false,
    "cache_dir": "cache"
  },
  "builds": {
    "decoder": {
      "components": ["decoder"],
      "pipeline": ["transformer_opt", "quantization"],
      "output_dir": "out/decoder"
    },
    "vision_encoder": {
      "components": ["vision_encoder"],
      "pipeline": ["transformer_opt"],
      "output_dir": "out/vision_encoder"
    }
  }
}
